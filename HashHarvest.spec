# -*- mode: python ; coding: utf-8 -*-

block_cipher = None

a = Analysis(
    ['hashharvest/main.py'],
    pathex=[],
    binaries=[],
    datas=[('README.md', '.')],
    hiddenimports=[
        'PyQt6.sip',
        'vt',                          # VirusTotal lookup — lazily imported, so declare it
        'keyring.backends.Windows',    # keychain storage backend (Windows Credential Manager)
        'win32ctypes.pywin32',         # provides pywintypes/win32cred for keyring's backend
        'win32ctypes.pywin32.pywintypes',
        'win32ctypes.pywin32.win32cred',
    ],
    hookspath=['scripts/pyi_hooks'],
    hooksconfig={},
    runtime_hooks=[],
    excludes=[
        # --- Heavy Qt6 modules not used by this app ---
        'PyQt6.QtWebEngine',
        'PyQt6.QtWebEngineWidgets',
        'PyQt6.QtWebEngineCore',
        'PyQt6.QtWebChannel',
        'PyQt6.QtWebSockets',
        'PyQt6.QtMultimedia',
        'PyQt6.QtMultimediaWidgets',
        'PyQt6.QtBluetooth',
        'PyQt6.QtNetwork',
        'PyQt6.QtNfc',
        'PyQt6.QtPositioning',
        'PyQt6.QtLocation',
        'PyQt6.QtQml',
        'PyQt6.QtQuick',
        'PyQt6.QtQuickWidgets',
        'PyQt6.QtSql',
        'PyQt6.QtSvg',
        'PyQt6.QtXml',
        'PyQt6.QtXmlPatterns',
        'PyQt6.QtDesigner',
        'PyQt6.QtHelp',
        'PyQt6.QtTest',
        'PyQt6.Qt3DAnimation',
        'PyQt6.Qt3DCore',
        'PyQt6.Qt3DExtras',
        'PyQt6.Qt3DInput',
        'PyQt6.Qt3DLogic',
        'PyQt6.Qt3DRender',
        'PyQt6.QtOpenGL',
        'PyQt6.QtSensors',
        'PyQt6.QtSerialPort',
        'PyQt6.QtTextToSpeech',
        'PyQt6.QtChart',
        'PyQt6.QtDataVisualization',
        'PyQt6.QtPurchasing',
        'PyQt6.QtRemoteObjects',
        # --- Unused stdlib ---
        'tkinter',
        '_tkinter',
        'unittest',
        'pydoc',
        'doctest',
        'difflib',
        'distutils',
        # NOTE: do not exclude 'email' — http.client and aiohttp (vt-py) need it.
        'ftplib',
        'imaplib',
        'mailbox',
        'smtpd',
        'smtplib',
        'telnetlib',
        'xmlrpc',
        'curses',
        # --- Packages that may get pulled in transitively ---
        'lxml',           # pypdf has optional lxml dep; triggers deep recursion in hooks
        'setuptools',
        'pkg_resources',
        'numpy',
        'pandas',
        'scipy',
        'matplotlib',
        'PIL',
        'Pillow',
        'IPython',
        'cryptography',
        'OpenSSL',
    ],
    win_no_prefer_redirects=False,
    win_private_assemblies=False,
    cipher=block_cipher,
    noarchive=False,
    optimize=0,
)

pyz = PYZ(a.pure, a.zipped_data, cipher=block_cipher)

exe = EXE(
    pyz,
    a.scripts,
    a.binaries,
    a.zipfiles,
    a.datas,
    [],
    name='HashHarvest',
    debug=False,
    bootloader_ignore_signals=False,
    strip=False,
    upx=True,
    upx_exclude=['vcruntime140.dll', 'python3*.dll'],
    runtime_tmpdir=None,
    console=False,
    disable_windowed_traceback=False,
    argv_emulation=False,
    target_arch=None,
    codesign_identity=None,
    entitlements_file=None,
)
